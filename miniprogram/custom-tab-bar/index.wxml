<view class="tab-bar">
  <view class="tab-bar-bg"></view>
  <view class="tab-bar-content">
    <view 
      wx:for="{{list}}"
      wx:key="index"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-icon-wrapper">
        <view class="tab-icon icon-{{item.icon}}"></view>
      </view>
      <text class="tab-text">{{item.text}}</text>
    </view>
  </view>
</view>
