.tab-bar {
  position: fixed;
  bottom: 35px;
  left: 50%;
  transform: translateX(-50%);
  width: 300px;
  height: 60px;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-bar-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1a1a1a, #111111);
  border-radius: 30px;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5),
              0 0 0 1px rgba(255, 255, 255, 0.05),
              inset 0 1px 0 rgba(255, 255, 255, 0.05),
              0 0 10px 2px rgba(30, 144, 255, 0.25),
              0 0 20px 4px rgba(30, 144, 255, 0.12),
              0 0 40px 8px rgba(30, 144, 255, 0.06);
  backdrop-filter: blur(20px);
}

.tab-bar-content {
  position: relative;
  display: flex;
  width: 100%;
  height: 100%;
  align-items: center;
  justify-content: space-around;
  padding: 0 10px;
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
}

.tab-icon-wrapper {
  width: 25px;
  height: 25px;
  margin-bottom: 4px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 20px;
  height: 20px;
  position: relative;
  background: #999999;
}

.tab-item.active .tab-icon {
  background: #1e90ff;
}

