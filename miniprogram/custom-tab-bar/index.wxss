.tab-bar {
  position: fixed;
  bottom: 70rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 120rpx;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 大屏适配 */
@media screen and (min-width: 768px) {
  .tab-bar {
    width: 300px;
    height: 60px;
    bottom: 35px;
    min-width: 300px;
    max-width: 300px;
  }
  
  .tab-bar-bg {
    border-radius: 30px;
    min-width: 300px;
    max-width: 300px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5), 
                0 0 0 1px rgba(255, 255, 255, 0.05),
                inset 0 1px 0 rgba(255, 255, 255, 0.05),
                0 0 10px 2px rgba(30, 144, 255, 0.25),
                0 0 20px 4px rgba(30, 144, 255, 0.12),
                0 0 40px 8px rgba(30, 144, 255, 0.06);
  }
  
  .tab-bar-content {
    padding: 0 10px;
    min-width: 300px;
    max-width: 300px;
  }
  
  .tab-item {
    min-width: 100px;
    max-width: 100px;
  }
  
  .tab-icon-wrapper {
    width: 25px !important;
    height: 25px !important;
    margin-bottom: 4px !important;
  }
  
  .tab-icon {
    width: 20px !important;
    height: 20px !important;
  }
  
  .tab-text {
    font-size: 11px !important;
  }
}

.tab-bar-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1a1a1a, #111111);
  border-radius: 70rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.5), 
              0 0 0 1rpx rgba(255, 255, 255, 0.05),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.05),
              0 0 20rpx 4rpx rgba(30, 144, 255, 0.25),
              0 0 40rpx 8rpx rgba(30, 144, 255, 0.12),
              0 0 80rpx 15rpx rgba(30, 144, 255, 0.06);
  backdrop-filter: blur(20px);
}

.tab-bar-content {
  position: relative;
  display: flex;
  width: 100%;
  height: 100%;
  align-items: center;
  justify-content: space-around;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
}

/* 图标容器 */
.tab-icon-wrapper {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 8rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 图标基础样式 */
.tab-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  background: #999999;
}

/* 获得焦点时的强调色 */
.tab-item.active .tab-icon {
  background: #1e90ff;
}

/* 对话图标 - 聊天气泡 */
