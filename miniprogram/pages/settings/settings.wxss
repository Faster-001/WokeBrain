.dialog-footer {
  display: flex;
  border-top: 1px solid var(--color-border);
}

.dialog-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 0;
  font-size: var(--font-md);
}

.dialog-btn-cancel {
  color: var(--color-text-secondary);
  border-right: 1px solid var(--color-border);
}

.dialog-btn-confirm {
  color: var(--color-primary);
  font-weight: 600;
}
