<view class="page-container">
  <view class="top-section">
    <view class="top-section-inner">
      <view class="input-group">
        <text class="input-label">Base URL (OpenAI Compatible)</text>
        <input
          class="input-field"
          placeholder="https://api.openai.com/v1"
          placeholder-class="input-placeholder"
          value="{{baseUrl}}"
          bindinput="onBaseUrlInput"
          maxlength="100"
        />
      </view>
      
      <view class="input-group">
        <text class="input-label">API Key</text>
        <view class="password-row">
          <input
            class="input-field"
            placeholder="sk-..."
            placeholder-class="input-placeholder"
            password="{{!passwordVisible}}"
            value="{{apiKey}}"
            bindinput="onApiKeyInput"
            maxlength="100"
          />
          <view class="eye-btn" bindtap="onToggleApiKeyVisible">
            <view class="eye-icon {{passwordVisible ? 'eye-open' : 'eye-close'}}">
              <view class="eye-svg"></view>
            </view>
          </view>
        </view>
        <view class="security-tip-row" bindtap="onSecurityTip">
          <text class="security-tip-icon">🔒</text>
          <text class="security-tip-text">API Key 加密存储于本地，离开页面自动隐藏</text>
          <text class="security-tip-arrow">›</text>
        </view>
      </view>
      
      <button class="save-btn" bindtap="onSaveAndFetch" loading="{{loading}}" disabled="{{loading}}">{{loading ? '获取中...' : '保存 & 获取模型'}}</button>
    </view>
  </view>
  
  <view class="bottom-section">
    <scroll-view
      class="model-list-scroll"
      scroll-y
      enhanced
      bounces
    >
      <view class="model-list">
        <view wx:if="{{loading}}" class="model-loading-row">
          <text class="model-loading-text">正在获取模型列表...</text>
        </view>
        <view
          class="model-item {{index < models.length - 1 ? 'model-border' : ''}}"
          wx:for="{{models}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-index="{{index}}"
          bindtap="onModelSelect"
          hover-class="model-item-active"
        >
          <block wx:if="{{index < models.length - 1}}">
            <view class="model-name-wrapper">
              <text class="model-name {{item.needMarquee ? 'model-name-marquee' : ''}}" style="{{item.needMarquee ? '--marquee-distance: -' + item.marqueeDistance + 'px' : ''}}">{{item.name}}</text>
            </view>
            <view class="radio-btn {{selectedModelId === item.id ? 'radio-selected' : ''}}">
              <view wx:if="{{selectedModelId === item.id}}" class="radio-dot"></view>
            </view>
          </block>
          <block wx:else>
            <input
              class="custom-model-input"
              placeholder="自定义模型 ID ..."
              placeholder-class="custom-model-placeholder"
              value="{{customModelId}}"
              bindinput="onCustomModelInput"
              maxlength="100"
            />
            <view class="radio-btn {{selectedModelId === item.id ? 'radio-selected' : ''}}">
              <view wx:if="{{selectedModelId === item.id}}" class="radio-dot"></view>
            </view>
          </block>
        </view>
      </view>
      <view class="model-list-bottom-space"></view>
    </scroll-view>
  </view>
</view>