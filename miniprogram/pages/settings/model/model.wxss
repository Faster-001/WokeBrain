.save-btn {
  width: 100%;
  height: 44px;
  background: var(--gradient-primary);
  color: #ffffff;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  box-shadow: var(--shadow-primary);
  margin-top: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 44px;
  padding: 0;
}

/* 安全提示行 */
.security-tip-row {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 6px;
  padding: 4px 0;
}

.security-tip-icon {
  font-size: 12px;
}

.security-tip-text {
  flex: 1;
  font-size: 11px;
  color: var(--color-text-tertiary);
}

.security-tip-arrow {
  font-size: 14px;
  color: var(--color-text-tertiary);
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.bottom-section {
  flex: 1;
  overflow: hidden;
  padding: 0 var(--spacing-md);
  max-width: 600px;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

.model-list-scroll {
  height: 100%;
  padding: var(--spacing-md) 0;
}

.model-list {
  background: var(--gradient-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-primary-alpha-3);
  box-shadow: var(--shadow-sm), 0 0 6px 1px rgba(30, 144, 255, 0.08);
  overflow: hidden;
}

.model-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px var(--spacing-md);
  transition: background-color var(--transition-fast);
}

.model-item-active {
  background-color: rgba(255, 255, 255, 0.03);
}

.model-border {
  border-bottom: 1px solid var(--color-border);
}

.model-name-wrapper {
  flex: 1;
  overflow: hidden;
  margin-right: var(--spacing-md);
}

.model-name {
  font-size: var(--font-lg);
  color: var(--color-text-primary);
  font-weight: 400;
  white-space: nowrap;
  display: inline-block;
}

.model-name-marquee {
  animation: marquee 10s linear infinite;
}

@keyframes marquee {
  0% {
    transform: translateX(0);
  }
  10% {
    transform: translateX(0);
  }
  90% {
    transform: translateX(var(--marquee-distance, -100%));
  }
  100% {
    transform: translateX(var(--marquee-distance, -100%));
  }
}

.custom-model-input {
  flex: 1;
  height: 40px;
  background-color: transparent;
  border: none;
  padding: 0;
  font-size: var(--font-lg);
  color: var(--color-text-primary);
  margin-right: var(--spacing-md);
}

.custom-model-placeholder {
  color: var(--color-text-disabled);
}

.radio-btn {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid var(--color-text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.radio-selected {
  border-color: var(--color-primary);
}

.radio-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background-color: var(--color-primary);
}

.model-list-bottom-space {
  height: 92px;
}

.model-loading-row {
  padding: var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid var(--color-border);
}

.model-loading-text {
  font-size: var(--font-md);
  color: var(--color-text-tertiary);
}