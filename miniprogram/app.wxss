/**app.wxss**/

page {
  --color-bg-primary: #0a0a0a;
  --color-bg-secondary: #111111;
  --color-bg-tertiary: #1a1a1a;
  --color-bg-card: #161616;
  --color-border: #222222;
  --color-border-light: #2a2a2a;

  --color-primary: #1e90ff;
  --color-primary-dark: #0066cc;
  --color-primary-light: #4da6ff;
  --color-primary-alpha: rgba(30, 144, 255, 0.1);
  --color-primary-alpha-2: rgba(30, 144, 255, 0.2);
  --color-primary-alpha-3: rgba(30, 144, 255, 0.3);
  --color-course-surface: #0b2033;
  --color-course-surface-strong: #081827;
  --color-course-border: #174766;
  --color-course-marker: #58b6f5;
  --color-course-title: #4da6ff;
  --color-course-time: #6694b7;
  --color-course-meta: #c8ddec;
  --color-course-location: #ffffff;

  --color-text-primary: #ffffff;
  --color-text-secondary: #999999;
  --color-text-tertiary: #666666;
  --color-text-disabled: #444444;

  --gradient-primary: linear-gradient(135deg, #1e90ff, #0066cc);
  --gradient-bg: linear-gradient(135deg, #1a1a1a, #111111);
  --gradient-card: linear-gradient(135deg, #161616, #111111);

  --shadow-sm: 0 1px 5px rgba(0, 0, 0, 0.3);
  --shadow-md: 0 2px 10px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 5px 20px rgba(0, 0, 0, 0.5);
  --shadow-primary: 0 2px 10px rgba(30, 144, 255, 0.3);
  --shadow-course: 0 2px 6px rgba(0, 0, 0, 0.22);

  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 15px;
  --radius-xl: 20px;
  --radius-full: 9999px;

  --spacing-xs: 5px;
  --spacing-2xs: 3px;
  --spacing-3xs: 2px;
  --spacing-4xs: 1px;
  --spacing-sm: 10px;
  --spacing-md: 15px;
  --spacing-lg: 20px;
  --spacing-xl: 30px;

  --font-xs: 10px;
  --font-2xs: 9px;
  --font-3xs: 8px;
  --font-sm: 12px;
  --font-md: 14px;
  --font-lg: 16px;
  --font-xl: 18px;
  --font-2xl: 20px;
  --font-3xl: 24px;

  --transition-fast: 0.15s ease;
  --transition-normal: 0.3s ease;
  --transition-slow: 0.5s ease;

  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-md);
  line-height: 1.6;
}

.page-scroll {
  background-color: var(--color-bg-primary);
}

.page-content {
  padding: 15px 15px 0;
}

@media screen and (min-width: 600px) {
  .page-content {
    max-width: 600px;
    margin: 0 auto;
  }
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 100px 0;
  box-sizing: border-box;
}

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.bg-primary { background-color: var(--color-bg-primary); }
.bg-secondary { background-color: var(--color-bg-secondary); }
.bg-card { background-color: var(--color-bg-card); }
.border { border: 1px solid var(--color-border); }
.rounded { border-radius: var(--radius-md); }
.shadow { box-shadow: var(--shadow-md); }

.btn-primary {
  background: var(--gradient-primary);
  color: var(--color-text-primary);
  border-radius: var(--radius-full);
  padding: 12px 24px;
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
  box-shadow: var(--shadow-primary);
  transition: all var(--transition-normal);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.card {
  background: var(--gradient-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-normal);
}

.card:active {
  transform: scale(0.98);
  background-color: var(--color-bg-tertiary);
}

.input {
  background-color: var(--color-bg-tertiary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  padding: 12px 16px;
  font-size: var(--font-md);
  color: var(--color-text-primary);
  transition: all var(--transition-normal);
}

.input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 1px var(--color-primary-alpha-2);
}

.input-placeholder {
  color: var(--color-text-tertiary);
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  background-color: var(--color-primary-alpha);
  color: var(--color-primary);
  font-size: var(--font-sm);
  border-radius: var(--radius-full);
  border: 1px solid var(--color-primary-alpha-3);
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.fade-in {
  animation: fadeIn var(--transition-normal) ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
