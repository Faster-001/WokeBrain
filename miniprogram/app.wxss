/**app.wxss**/

/* 深色主题变量 */
page {
  --color-bg-primary: #0a0a0a;
  --color-bg-secondary: #111111;
  --color-bg-tertiary: #1a1a1a;
  --color-bg-card: #161616;
  --color-border: #222222;
  --color-border-light: #2a2a2a;
  
  /* 蓝色主题色 */
  --color-primary: #1e90ff;
  --color-primary-dark: #0066cc;
  --color-primary-light: #4da6ff;
  --color-primary-alpha: rgba(30, 144, 255, 0.1);
  --color-primary-alpha-2: rgba(30, 144, 255, 0.2);
  --color-primary-alpha-3: rgba(30, 144, 255, 0.3);
  
  /* 文字颜色 */
  --color-text-primary: #ffffff;
  --color-text-secondary: #999999;
  --color-text-tertiary: #666666;
  --color-text-disabled: #444444;
  
  /* 渐变色 */
  --gradient-primary: linear-gradient(135deg, #1e90ff, #0066cc);
  --gradient-bg: linear-gradient(135deg, #1a1a1a, #111111);
  --gradient-card: linear-gradient(135deg, #161616, #111111);
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 10rpx 40rpx rgba(0, 0, 0, 0.5);
  --shadow-primary: 0 4rpx 20rpx rgba(30, 144, 255, 0.3);
  
  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 30rpx;
  --radius-xl: 40rpx;
  --radius-full: 9999rpx;
  
  /* 间距 */
  --spacing-xs: 10rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 30rpx;
  --spacing-lg: 40rpx;
  --spacing-xl: 60rpx;
  
  /* 字体大小 */
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 40rpx;
  --font-3xl: 48rpx;
  
  /* 动画 */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.3s ease;
  --transition-slow: 0.5s ease;
  
  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-md);
  line-height: 1.6;
}

/* 全局容器 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 通用工具类 */
.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-tertiary {
  color: var(--color-text-tertiary);
}

.bg-primary {
  background-color: var(--color-bg-primary);
}

.bg-secondary {
  background-color: var(--color-bg-secondary);
}

.bg-card {
  background-color: var(--color-bg-card);
}

.border {
  border: 1rpx solid var(--color-border);
}

.rounded {
  border-radius: var(--radius-md);
}

.shadow {
  box-shadow: var(--shadow-md);
}

/* 按钮样式 */
.btn-primary {
  background: var(--gradient-primary);
  color: var(--color-text-primary);
  border-radius: var(--radius-full);
  padding: 24rpx 48rpx;
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
  box-shadow: var(--shadow-primary);
  transition: all var(--transition-normal);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 卡片样式 */
.card {
  background: var(--gradient-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-normal);
}

.card:active {
  transform: scale(0.98);
  background-color: var(--color-bg-tertiary);
}

/* 输入框样式 */
.input {
  background-color: var(--color-bg-tertiary);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-full);
  padding: 24rpx 32rpx;
  font-size: var(--font-md);
  color: var(--color-text-primary);
  transition: all var(--transition-normal);
}

.input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2rpx var(--color-primary-alpha-2);
}

.input-placeholder {
  color: var(--color-text-tertiary);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: var(--color-primary-alpha);
  color: var(--color-primary);
  font-size: var(--font-sm);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--color-primary-alpha-3);
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 渐入动画 */
.fade-in {
  animation: fadeIn var(--transition-normal) ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 脉冲动画 */
.pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}
